# Both backend/llm.py (outfit explanations) and vision/extractor.py (garment
# extraction) authenticate via ADC — no API key needed.
# Cloud Run: the runtime service account is used automatically.
# Local dev:  run `gcloud auth application-default login` once before starting the server.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model names — each component can be tuned independently.
VERTEX_AI_MODEL=gemini-3.1-pro-preview       # backend/llm.py  (outfit explanations)
VERTEX_AI_VISION_MODEL=gemini-2.5-flash      # vision/extractor.py (garment extraction)
HF_API_TOKEN=
# IMAGE_GEN_PROVIDER=hf (default; uses FLUX.1-schnell, free tier available)
# GARMENT_ASSET_SIZE=512

IMAGE_STORAGE_BACKEND=supabase
LOCAL_GARMENTS_DIR=outputs/local_garments
LOCAL_ASSET_BASE_URL=http://127.0.0.1:8000

# No spaces around = (required for shell sourcing and for python-dotenv)
SERPAPI_KEY=<put_yours_here>

SUPABASE_URL=<>
SUPABASE_SERVICE_KEY=<>
SUPABASE_GARMENTS_BUCKET=garments
SUPABASE_GARMENTS_TABLE=garments
# OAuth signups (no Supabase Auth): run scripts/sql/analytics_registered_users.sql in Supabase, then
# the app POSTs /analytics/register after login. Override table name if needed:
# SUPABASE_SIGNUPS_TABLE=analytics_registered_users

# Waitlist via Formspree Submissions API (often requires a paid Formspree plan). Form hash from dashboard URL.
# FORMSPREE_FORM_ID=yourFormHash
# FORMSPREE_API_KEY=your_formspree_api_key
# If set, these take priority over CSV / Supabase waitlist for GET /api/metrics ``waitlist``.

# Waitlist (GET /analytics/metrics): use a published CSV URL (recommended for Google Sheets / Excel
# exported to Sheets). Fetched on every metrics request — no Google API key if the link is public.
# Example (replace SHEET_ID and gid for the correct tab):
# WAITLIST_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=0
# WAITLIST_CSV_SKIP_HEADER=true
# Fallback if no CSV URL: Supabase table row count
# SUPABASE_WAITLIST_TABLE=waitlist

# Internal dashboard: GET /analytics/metrics
# ANALYTICS_INTERNAL_API_KEY=generate-a-long-random-string
# Temporary: allow calls without X-Analytics-Key even if ANALYTICS_INTERNAL_API_KEY is set (e.g. ngrok week)
# ANALYTICS_SKIP_KEY_AUTH=true
# Demo / UI wiring: fixed counts; response includes dummy_data: true
# ANALYTICS_USE_DUMMY_METRICS=true
#
# --- ~1 week: expose /analytics/metrics over the internet (tunnel) ---
# 1) Backend: from repo root, .env is loaded automatically — no need for export $(grep .env | xargs)
#    PYTHONPATH=. uvicorn backend.main:app --host 0.0.0.0 --port 8000
# 2) Tunnel: ngrok http 8000   OR   cloudflared tunnel --url http://localhost:8000
# 3) Share (Startup Studio slide shape — four fields only): https://<tunnel-subdomain>/api/metrics
#    Full detail: https://<tunnel-subdomain>/analytics/metrics
# 4) If a browser dashboard gets CORS errors, add the tunnel origin (no trailing slash), e.g.:
# ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,https://YOUR-SUBDOMAIN.ngrok-free.app

# GA4 Data API (active_users + page_views on /api/metrics):
# 1) analytics.google.com → Admin (gear) → Property settings → Property details → copy numeric Property ID.
# 2) Cloud Run: set secret GA4_PROPERTY_ID to that number (no "properties/" prefix).
# 3) GA Admin → Property → Property access management → Add the Cloud Run runtime service account
#    (PROJECT_NUMBER-compute@developer.gserviceaccount.com) with Viewer (or Analytics Viewer).
# 4) Web app: set EXPO_PUBLIC_GA_MEASUREMENT_ID=G-... in the Expo build so hits reach GA4.
# Local only:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# GA4_PROPERTY_ID=123456789

# ── Frontend (Expo) — Google OAuth ───────────────────────────────────────────
# OAuth client IDs from Google Cloud Console → APIs & Services → Credentials.
# Web client ID is required for browser sign-in; iOS/Android IDs are optional.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Stable redirect URI registered in Google Cloud Console (Authorized redirect URIs).
# All web builds — production and PR preview channels — use this single URL so
# only one entry is needed in Google Cloud Console.
# In CI this is set to https://<FIREBASE_PROJECT_ID>.web.app automatically.
# For local dev, register http://localhost:8081 in Google Cloud Console and set:
EXPO_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:8081
