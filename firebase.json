{
  "hosting": {
    "public": "misfitai-mobile/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/wardrobe/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/vision/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/media-ingestion",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/media-ingestion/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/users/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/recommendations/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/weather/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/calendar/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/analytics/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "misfitai-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
